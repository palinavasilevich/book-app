    "utils": "@/shared/lib/utils",
    "ui": "@/shared/ui/kit",
    "lib": "@/shared/lib",
    "hooks": "@/shared/hooks"
  },
  "menuColor": "default",
  "menuAccent": "bold",
  "registries": {}
}
